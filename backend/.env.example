# Application
NODE_ENV=development
PORT=3000
DEBATE_CHAT_WS_PORT=8080

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/heimdall_db

# Redis / BullMQ
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Gemini
GEMINI_API_KEY=
GEMINI_ANALYZER_MODEL=gemini-3.5-flash
GEMINI_FACT_CHECKER_MODEL=gemini-3.5-flash
GEMINI_JUDGE_MODEL=gemini-3.5-flash
GEMINI_REQUEST_TIMEOUT_MS=60000
GEMINI_MAX_RETRIES=3

# Analyzer limits
ANALYZER_MAX_COMPONENTS_PER_TURN=10
ANALYZER_MAX_FACT_CHECK_TARGETS_PER_TURN=5
ANALYZER_MAX_COMPONENT_STATEMENT_LENGTH=1000

# Fact checker limits
FACT_CHECK_MAX_TARGETS_PER_BATCH=5
FACT_CHECK_MAX_REASON_LENGTH=2000
FACT_CHECK_MAX_SOURCES_PER_RESULT=5
FACT_CHECK_ENABLED=true

# Judge limits
JUDGE_MAX_OVERALL_REASON_LENGTH=3000
JUDGE_MAX_FEEDBACK_LENGTH=1500
